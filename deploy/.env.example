# 复制为 .env 后可修改；不创建 .env 则使用下列默认值
# 使用方式：在 deploy 目录执行 docker compose --env-file .env up -d，或在项目根目录 docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d

# MySQL root 密码（XXL-JOB 等会使用同一账号）
MYSQL_ROOT_PASSWORD=root123

# Nacos 控制台/API 鉴权 Token（可随机生成一长串）
# NACOS_AUTH_TOKEN=your-secret-token

# Grafana 控制台管理员
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# MinIO 控制台与 API
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
